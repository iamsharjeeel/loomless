# --- Supabase (Auth + Postgres) ---
# Public — safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Cloudflare R2 (video storage, S3-compatible API) ---
# Server-only. NEVER expose these to the client — only the presign API route
# (app/api/r2/presign) and lib/r2.ts touch them.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
